{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,

    "types": ["node"],
    "baseUrl": ".",

    "paths": {
      "@/*": ["resources/js/*"]
    },
    "allowSyntheticDefaultImports": true
  },
  "include": ["resources/js/**/*", "resources/**/*.ts", "resources/**/*.tsx"]
}